{
  "type": "component",
  "metadata": {
    "svelteMajor": 5
  },
  "schema": {
    "name": "bb-kanban-draggable",
    "friendlyName": "Kanban",
    "description": "Dragable Kanban cards area allowing for status changes.",
    "icon": "ViewColumn",
    "draggable": false,
    "features": {
      "state": true,
      "showNotificationAction": true,
      "sidePanel": true,
      "rowSelection": true
    },
    "settings": [
      {
        "type": "text",
        "key": "title",
        "label": "Title"
      },
      {
        "type": "number",
        "label": "Card widths",
        "key": "CardWidths",
        "defaultValue": 300,
        "min": 300
      },
      {
        "type": "dataProvider",
        "label": "Provider",
        "key": "dataProvider",
        "required": true
      },
      {
        "type": "field",
        "label": "Single Select Field",
        "key": "kanbanCardTitles",
        "dependsOn": "dataProvider",
        "explanation": {
          "typeSupport": {
            "supported": [
              "options"
            ]
          }
        },
        "required": true
      },
      {
        "type": "event",
        "label": "On Click",
        "key": "onClick",
        "context": [
          {
            "label": "Card ID",
            "key": "cardId"
          }
        ]
      }
    ]
  }
}
